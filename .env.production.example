# ============================================
# Eaty - Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in values

# Next.js
NODE_ENV=production
NEXT_PUBLIC_URL=https://your-domain.com

# NextAuth
NEXTAUTH_SECRET=your-32-character-secret-here-generate-with-openssl
NEXTAUTH_URL=https://your-domain.com

# Database (PostgreSQL - Render, Supabase, Neon, etc.)
DATABASE_URL=postgresql://user:password@host:5432/eaty?schema=public

# Firebase Admin SDK (for push notifications)
# Paste the entire service account JSON object
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"","private_key_id":"","private_key":"","client_email":"","client_id":"","auth_uri":"","token_uri":"","auth_provider_x509_cert_url":"","client_x509_cert_url":""}

# Email (for password reset, OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com

# WhatsApp Business API (optional)
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Paystack
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_SECRET_KEY=sk_live_...

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
FLUTTERWAVE_SECRET_KEY=FLWSECK-...

# Security
CORS_ORIGIN=https://your-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
