# App
APP_NAME="FoodAppi"
APP_ENV=development

# Backend API URL (Express.js backend on Render)
NEXT_PUBLIC_API_URL=http://localhost:4000

# JWT Secret (must match backend JWT_SECRET)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL
NEXTAUTH_URL=http://localhost:3000

# Google Maps
GOOGLE_MAP_KEY=

# Currency
CURRENCY=USD
CURRENCY_SYMBOL=$
CURRENCY_POSITION=left
CURRENCY_DECIMAL_POINT=2

# Date/Time
TIMEZONE=UTC
DATE_FORMAT=YYYY-MM-DD
TIME_FORMAT=HH:mm

# Mail (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@foodappi.com

# File Storage (local by default, set AWS for S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=

# Demo Mode
DEMO=false

# PWA Icons
D_72x72="/images/icons/icon-72x72.png"
D_96x96="/images/icons/icon-96x96.png"
D_128x128="/images/icons/icon-128x128.png"
D_144x144="/images/icons/icon-144x144.png"
D_152x152="/images/icons/icon-152x152.png"
D_192x192="/images/icons/icon-192x192.png"
D_384x384="/images/icons/icon-384x384.png"
D_512x512="/images/icons/icon-512x512.png"
